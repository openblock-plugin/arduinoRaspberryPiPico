{
  "name": "arduino-raspberry-pi-pico",
  "version": "1.0.0",
  "author": "ArthurZheng",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/openblock-plugin/arduinoRaspberryPiPico.git"
  },
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "dev": "npx openblock-registry-cli dev",
    "build": "npx openblock-registry-cli build",
    "build:obfuscate": "npx openblock-registry-cli build --obfuscate",
    "publish": "npx openblock-registry-cli publish",
    "publish:dry": "npx openblock-registry-cli publish --dry-run",
    "validate": "npx openblock-registry-cli validate",
    "i18n:update": "npx openblock-registry-cli i18n update",
    "lint": "eslint . --ext .js --fix"
  },
  "openblock": {
    "name": "Raspberry Pi Pico",
    "deviceId": "arduinoRaspberryPiPico",
    "manufactor": "raspberrypi",
    "learnMore": "https://www.raspberrypi.com/products/raspberry-pi-pico/",
    "type": "arduino",
    "iconURL": "./assets/arduinoRaspberryPiPico.png",
    "description": {
      "formatMessage": {
        "id": "arduinoRaspberryPiPico.description",
        "default": "A friendly, easy-to-use microcontroller board that brings your electronics ideas to life."
      }
    },
    "bluetoothRequired": false,
    "serialportRequired": true,
    "defaultBaudRate": "115200",
    "internetConnectionRequired": false,
    "launchPeripheralConnectionFlow": true,
    "useAutoScan": false,
    "connectionIconURL": "./assets/arduinoRaspberryPiPico-illustration.svg",
    "connectionSmallIconURL": "./assets/arduinoRaspberryPiPico-small.svg",
    "main": "./src/arduinoRaspberryPiPico.js",
    "generator": "./src/generator.js",
    "translations": "./src/translations.js",
    "toolchains": "arduino-rp2040-rp2040",
    "programMode": ["upload"],
    "tags": ["arduino"],
    "helpLink": "https://wiki.openblock.cc/general-hardware-guidelines/boards/raspberry-pi-pico",
    "libraries": "./libraries"
  },
  "devDependencies": {
    "babel-eslint": "^10.0.1",
    "eslint": "^5.3.0",
    "eslint-config-scratch": "^5.0.0",
    "husky": "^9.0.0"
  }
}
